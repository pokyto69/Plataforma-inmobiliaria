NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://127.0.0.1:5174,http://localhost:5174
PARTNER_API_KEYS=demo-partner-key
API_RATE_LIMIT=180
VALUATION_RATE_LIMIT=30
USER_PROPERTIES_PATH=server/data/userProperties.json
VITE_API_TARGET=http://127.0.0.1:3000
# SSL and Domain Settings
DOMAIN=localhost
ACME_EMAIL=admin@example.com

# PostgreSQL Database Settings (Used by Docker compose and prod server)
DB_USER=habitatiq
DB_PASSWORD=habitatiq_secure_pass
DB_NAME=habitatiq_db
DATABASE_URL=postgres://habitatiq:habitatiq_secure_pass@localhost:5432/habitatiq_db
