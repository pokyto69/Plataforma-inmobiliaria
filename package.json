{
  "name": "plataforma-inmobiliaria-inteligente",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Portal web inmobiliario con MVC, React, analisis de precios, seguridad, Docker y CI/CD.",
  "scripts": {
    "dev": "concurrently -n API,WEB -c cyan,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node --watch --env-file=.env server/server.js",
    "dev:web": "vite --host 127.0.0.1",
    "build": "vite build",
    "start": "node server/server.js",
    "test": "node --test tests/api.test.js tests/priceEstimator.test.js",
    "perf": "node tests/performance/autocannon.mjs",
    "ci": "npm run test && npm run build",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "lucide-react": "^0.468.0",
    "pg": "^8.11.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sanitize-html": "^2.13.1",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
